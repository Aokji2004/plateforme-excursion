# Copiez ce fichier en .env.local (dev) ou configurez les variables sur l'hébergeur (prod).
# En production, NEXT_PUBLIC_API_BASE_URL doit pointer vers l'URL publique de l'API.

# URL de l'API backend (obligatoire en production)
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000

# URL publique du frontend (recommandé en production : liens de candidature et codes QR)
# Ex. https://plateforme-excursion-frontend.onrender.com
# NEXT_PUBLIC_APP_URL=
