{
  "name": "backend",
  "version": "1.0.0",
  "main": "dist/src/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc",
    "start": "node dist/src/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "seed": "ts-node-dev --transpile-only src/seed.ts",
    "seed:prod": "node dist/src/seed.js",
    "add:inscriptions": "ts-node-dev --transpile-only src/addInscriptions.ts",
    "add:activities": "ts-node-dev --transpile-only src/addActivities.ts",
    "add:family": "ts-node-dev --transpile-only src/addFamilyData.ts",
    "add:more": "ts-node-dev --transpile-only src/addMoreData.ts",
    "export-data": "ts-node-dev --transpile-only src/scripts/export-data.ts",
    "import-data": "ts-node-dev --transpile-only src/scripts/import-data.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "@prisma/adapter-pg": "^7.4.0",
    "@prisma/client": "^7.4.0",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.16.3"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.0.8",
    "@types/pg": "^8.16.0",
    "prisma": "^7.4.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
