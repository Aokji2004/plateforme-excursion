generator client {
  provider   = "prisma-client"
  output     = "../generated/prisma"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                Int                    @id @default(autoincrement())
  email             String                 @unique
  passwordHash      String
  firstName         String
  lastName          String
  matricule         String?                @unique
  role              UserRole               @default(EMPLOYEE)
  points            Int                    @default(0)
  
  // Situation familiale
  maritalStatus     MaritalStatus?
  spouse            String?
  spouseEmail       String?
  
  // Profil créé depuis formulaire public (candidature) sans être dans la liste initiale
  profileIncomplete Boolean                @default(false)
  
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt

  createdExcursions Excursion[]            @relation("ExcursionCreatedBy")
  applications      ExcursionApplication[]
  pointHistoryAsUser  UserPointHistory[]   @relation("UserPointHistoryUser")
  pointHistoryAsAdmin UserPointHistory[]   @relation("UserPointHistoryCreatedBy")
  children          Child[]
}

model Child {
  id          Int       @id @default(autoincrement())
  firstName   String
  lastName    String
  dateOfBirth DateTime
  gender      Gender
  parentId    Int
  parent      User      @relation(fields: [parentId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([parentId])
}

model Excursion {
  id                        Int                      @id @default(autoincrement())
  title                     String
  city                      String
  hotelName                 String
  hotelCategory             String
  type                      ExcursionType
  startDate                 DateTime
  endDate                   DateTime
  durationDays              Int
  totalSeats                Int
  status                    ExcursionStatus          @default(OPEN)
  
  // Dates d'inscription
  registrationStartDate     DateTime?
  registrationEndDate       DateTime?
  
  // Dates de paiement
  paymentStartDate          DateTime?
  paymentEndDate            DateTime?
  waitingListPaymentDate    DateTime?
  
  // Prix
  price                     Float?
  childPrice                Float?
  
  // Description et image
  description               String?                  @db.Text
  imageUrl                  String?
  
  // Types d'agent (pour l'instant String, peut devenir enum plus tard)
  agentTypes                String?
  
  // Type d'activité (prestation: Excursion, Diner, Escapade, etc.) — même liste que Types d'activités
  activityTypeId            Int?
  activityType              ActivityType?            @relation(fields: [activityTypeId], references: [id])
  
  // Statut de sélection
  selectionStatus           SelectionStatus          @default(NOT_STARTED)
  selectionMaxPlaces        Int?                     // Nombre max de places sélectionnées (défini lors du démarrage)
  paymentDeadline           DateTime?
  pointsCreditedAt          DateTime?               // Date à laquelle les points ont été crédités (évite double crédit)
  
  // Lien d'inscription public (partagé aux employés, sans login)
  inscriptionToken          String?                  @unique  // token pour URL /candidater/[token]
  inscriptionLinkValidFrom  DateTime?                // début de validité du lien
  inscriptionLinkValidUntil DateTime?                // fin de validité du lien
  externalFormUrl           String?                  @db.Text // si renseigné : lien/QR pointent vers ce formulaire (ex. Microsoft Forms)
  inscriptionFormTitle      String?                  @db.Text // titre personnalisé du formulaire intégré
  inscriptionFormDescription String?                 @db.Text // instructions / contenu personnalisé du formulaire intégré
  
  createdAt                 DateTime                 @default(now())
  updatedAt                 DateTime                 @updatedAt

  createdById               Int
  createdBy                 User                     @relation("ExcursionCreatedBy", fields: [createdById], references: [id])

  days                      ExcursionDay[]
  applications              ExcursionApplication[]
  stats                     ExcursionStatsSnapshot[]
  selectionHistory          SelectionHistory[]
}

model ExcursionDay {
  id          Int       @id @default(autoincrement())
  excursionId Int
  dayIndex    Int
  title       String
  description String

  excursion   Excursion @relation(fields: [excursionId], references: [id])
}

model ExcursionApplication {
  id                          Int                     @id @default(autoincrement())
  userId                      Int
  excursionId                 Int
  status                      ApplicationStatus       @default(PENDING)
  inscriptionStatus           InscriptionStatus       @default(INSCRIT)
  originalInscriptionStatus   InscriptionStatus       @default(INSCRIT)
  computedScore               Float?                  // score au moment du classement
  selectionOrder              Int?                    // ordre de sélection (1er, 2e, etc.)
  paymentConfirmed            Boolean                 @default(false)
  paymentConfirmedDate        DateTime?
  createdAt                   DateTime                @default(now())
  updatedAt                   DateTime                @updatedAt
  inscriptionFirstName        String?                 // prénom saisi lors de la candidature publique
  inscriptionLastName         String?                 // nom saisi lors de la candidature publique
  inscriptionAddress          String?                 @db.Text  // adresse saisie lors de la candidature publique
  inscriptionPhone            String?                 // téléphone saisi lors de la candidature publique

  user                        User                    @relation(fields: [userId], references: [id])
  excursion                   Excursion               @relation(fields: [excursionId], references: [id])
  
  @@unique([userId, excursionId])
}

model ActivityType {
  id              Int         @id @default(autoincrement())
  title           String
  beneficiary     String      // FAMILY, SINGLE, or COUPLE
  points          Int
  pointsPerChild  Int
  pointsConjoint  Int         @default(0)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  excursions      Excursion[]
}

model PointRule {
  id          Int      @id @default(autoincrement())
  name        String
  description String?
  weight      Float    @default(1.0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model UserPointHistory {
  id          Int      @id @default(autoincrement())
  userId      Int
  delta       Int
  reason      String?
  createdById Int
  createdAt   DateTime @default(now())

  user        User     @relation("UserPointHistoryUser", fields: [userId], references: [id])
  createdBy   User     @relation("UserPointHistoryCreatedBy", fields: [createdById], references: [id])
}

model ExcursionStatsSnapshot {
  id                Int       @id @default(autoincrement())
  excursionId       Int
  totalApplications Int
  approvedCount     Int
  waitingListCount  Int
  createdAt         DateTime  @default(now())

  excursion         Excursion @relation(fields: [excursionId], references: [id])
}

model SelectionHistory {
  id                      Int       @id @default(autoincrement())
  excursionId             Int
  action                  SelectionAction
  applicationId           Int?
  participantName         String
  participantEmail        String
  previousStatus          InscriptionStatus?
  newStatus               InscriptionStatus?
  reason                  String?
  createdByAdminId        Int?
  createdAt               DateTime  @default(now())

  excursion               Excursion @relation(fields: [excursionId], references: [id])
}

enum UserRole {
  EMPLOYEE
  ADMIN
}

enum ExcursionType {
  FAMILY
  SINGLE
  COUPLE
}

enum ExcursionStatus {
  OPEN
  FULL
  CLOSED
}

enum ApplicationStatus {
  PENDING
  APPROVED
  REJECTED
  WAITING_LIST
}

enum InscriptionStatus {
  INSCRIT
  SELECTIONNE
  ATTENTE
  FINAL
  REFUSE
}

enum Gender {
  MALE
  FEMALE
}

enum MaritalStatus {
  SINGLE
  MARRIED
  DIVORCED
  WIDOWED
}

enum SelectionStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
  CLOSED
}

enum SelectionAction {
  SELECTION_STARTED
  PARTICIPANT_SELECTED
  PARTICIPANT_PROMOTED_FROM_WAITING
  PARTICIPANT_REFUSED
  PAYMENT_CONFIRMED
  SELECTION_CLOSED
  RESET_SELECTION
  PROMOTE_FROM_WAITING
}


