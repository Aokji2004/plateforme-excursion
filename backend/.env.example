# Copiez ce fichier en .env et adaptez les valeurs.
# Ne commitez jamais le fichier .env (il est dans .gitignore).

# Obligatoire (en production : les deux requis, JWT_SECRET min. 32 caractères)
DATABASE_URL="postgresql://postgres:VOTRE_MOT_DE_PASSE@localhost:5432/excursionocp"
JWT_SECRET=un_secret_jwt_long_et_aleatoire_min_32_caracteres

# Optionnel
PORT=4000
# En production : restreindre les origines CORS (ex. https://votre-front.vercel.app)
# CORS_ORIGIN=https://votre-app.com,https://www.votre-app.com

# Pour les scripts seed / setAdmin uniquement (ne pas utiliser le défaut en prod)
# SEED_ADMIN_EMAIL=admin@ocp.ma
# SEED_ADMIN_PASSWORD=mot_de_passe_fort
